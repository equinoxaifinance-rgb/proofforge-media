# Public demo mode works without credentials.
PROOFFORGE_DATA_DIR=./data
PROOFFORGE_ENABLE_LIVE=false
PROOFFORGE_ENABLE_JUDGE_SANDBOX=false
PROOFFORGE_OPERATOR_TOKEN=replace-with-a-long-random-value
PROOFFORGE_SIGNING_KEY=replace-with-an-independent-long-random-value
PROOFFORGE_JUDGE_CAPABILITY_KEY=replace-with-a-third-independent-long-random-value
PROOFFORGE_JUDGE_TTL_SECONDS=1800
PROOFFORGE_JUDGE_MAX_RUNS=3
PROOFFORGE_IMAGE_MODEL=gpt-image-2
PROOFFORGE_IMAGE_FALLBACK_MODEL=gpt-image-1.5
PROOFFORGE_JUDGE_MODEL=gpt-5.6-terra

# Required only for live OpenAI generation.
OPENAI_API_KEY=

# Required only for durable Backblaze B2 storage.
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=
B2_REGION=us-west-004
B2_PUBLIC_URL_BASE=
